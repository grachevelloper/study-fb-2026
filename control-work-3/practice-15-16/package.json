{
  "name": "practice-15-16",
  "version": "1.0.0",
  "description": "Практики 15-16: HTTPS + App Shell + WebSocket + Push",
  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build:client": "esbuild src/client/main.ts --bundle --outfile=public/app.js --target=es2020",
    "build:sw": "esbuild src/client/sw.ts --outfile=public/sw.js --target=es2020",
    "build": "npm run build:server && npm run build:client && npm run build:sw",
    "typecheck": "tsc -p tsconfig.client.json && tsc -p tsconfig.sw.json",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "generate-vapid": "npx web-push generate-vapid-keys"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.8.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/web-push": "^3.6.3",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
