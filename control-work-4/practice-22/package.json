{
  "name": "practice-22",
  "version": "1.0.0",
  "description": "Практика 22: Балансировка нагрузки в веб-приложениях",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "dev:backend1": "PORT=3000 INSTANCE_NAME=backend-1 tsx src/server.ts",
    "dev:backend2": "PORT=3001 INSTANCE_NAME=backend-2 tsx src/server.ts",
    "dev:backend3": "PORT=3002 INSTANCE_NAME=backend-3 tsx src/server.ts",
    "compose:nginx": "docker compose --profile nginx up --build",
    "compose:haproxy": "docker compose --profile haproxy up --build",
    "compose:down": "docker compose down"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
