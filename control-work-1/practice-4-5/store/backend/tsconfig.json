{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "../../../practice-4/store/backend/dist",
    "rootDir": "../../../practice-4/store/backend",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["../../../practice-4/store/backend/**/*.ts"],
  "exclude": ["../../../practice-4/store/backend/node_modules", "../../../practice-4/store/backend/dist"]
}